{
  "name": "pact-outcome-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "build": "tsc --noEmit && vite build --configLoader runner",
    "verify:dist": "node scripts/verify-dist.mjs",
    "test": "vitest run --config vitest.config.ts --configLoader runner",
    "test:watch": "vitest --config vitest.config.ts --configLoader runner",
    "reset": "node scripts/verify-scenario.mjs",
    "release:audit": "node scripts/release-audit.mjs",
    "release:check": "node scripts/release-audit.mjs --strict",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "verify:mcp": "node scripts/verify-mcp.mjs",
    "generate:agents": "node scripts/generate-gpt-artifacts.mjs",
    "generate:agents:resume": "node scripts/generate-gpt-artifacts.mjs --resume",
    "generate:agents:dry-run": "node scripts/generate-gpt-artifacts.mjs --dry-run",
    "promote:gpt-candidate": "node scripts/promote-gpt-candidate.mjs",
    "verify:gpt-artifact": "node scripts/verify-gpt-artifact.mjs",
    "judge:verify": "npm run reset && npm test && npm run verify:mcp && npm run validate:plugin && npm run generate:agents:dry-run && npm run verify:gpt-artifact && npm run build && npm run verify:dist"
  },
  "dependencies": {
    "@fontsource/dm-mono": "^5.2.6",
    "@fontsource/manrope": "^5.2.6",
    "@openai/agents": "^0.13.5",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "npm@10.9.2"
}
