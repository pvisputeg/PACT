{
  "name": "pact-outcome-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "reset": "node scripts/verify-scenario.mjs",
    "release:audit": "node scripts/release-audit.mjs",
    "release:check": "node scripts/release-audit.mjs --strict",
    "validate:plugin": "node scripts/validate-plugin.mjs",
    "verify:mcp": "node scripts/verify-mcp.mjs",
    "generate:agents": "node scripts/generate-gpt-artifacts.mjs",
    "generate:agents:dry-run": "node scripts/generate-gpt-artifacts.mjs --dry-run",
    "judge:verify": "npm run reset && npm test && npm run verify:mcp && npm run validate:plugin && npm run generate:agents:dry-run && npm run build"
  },
  "dependencies": {
    "@fontsource/dm-mono": "^5.2.6",
    "@fontsource/manrope": "^5.2.6",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "packageManager": "npm@10.9.2"
}
