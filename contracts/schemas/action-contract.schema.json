{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pact.local/schemas/action-contract.schema.json",
  "type": "object",
  "required": ["actionId", "description", "owner", "team", "rationale", "evidenceIds", "preconditions", "dependencies", "parameters", "estimatedCost", "estimatedEffect", "approvalRequired", "toolOperation", "status", "recovery"],
  "properties": {
    "actionId": {"type": "string", "pattern": "^ACT-[0-9]{3}$"},
    "description": {"type": "string", "minLength": 5},
    "owner": {"type": "string", "minLength": 1},
    "team": {"enum": ["Finance", "Procurement", "Manufacturing", "Logistics", "Customer", "Outcome Office"]},
    "rationale": {"type": "string", "minLength": 10},
    "evidenceIds": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "preconditions": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string", "pattern": "^ACT-[0-9]{3}$"}},
    "parameters": {"type": "object"},
    "estimatedCost": {"type": "number", "minimum": 0},
    "estimatedEffect": {"type": "number"},
    "approvalRequired": {"type": "boolean"},
    "toolOperation": {"type": "string"},
    "status": {"enum": ["proposed", "blocked", "ready", "executing", "complete", "failed"]},
    "result": {"type": ["object", "null"]},
    "recovery": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
