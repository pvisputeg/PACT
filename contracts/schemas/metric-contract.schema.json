{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pact.local/schemas/metric-contract.schema.json",
  "type": "object",
  "required": ["metricId", "name", "version", "businessPurpose", "owner", "entityGrain", "numerator", "denominator", "invariants", "historicalControl"],
  "properties": {
    "metricId": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "businessPurpose": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "entityGrain": {"type": "string", "const": "committed_revenue"},
    "numerator": {"type": "string", "minLength": 1},
    "denominator": {"type": "string", "minLength": 1},
    "exclusions": {"type": "array", "items": {"type": "string"}},
    "dimensions": {"type": "array", "items": {"type": "string"}},
    "invariants": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "historicalControl": {
      "type": "object",
      "required": ["period", "expectedValue", "tolerancePercentagePoints"],
      "properties": {
        "period": {"type": "string"},
        "expectedValue": {"type": "number", "minimum": 0, "maximum": 100},
        "tolerancePercentagePoints": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "contentHash": {"type": "string"}
  },
  "additionalProperties": false
}
